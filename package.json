{
  "name": "toio-mcp",
  "version": "1.0.0",
  "description": "MCP server for controlling toio cubes via natural language",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:web": "tsx src/server.ts",
    "start:web": "node dist/server.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@toio/cube": "^1.0.0",
    "@toio/scanner": "^1.0.0",
    "dotenv": "^17.3.1",
    "hono": "^4.7.0",
    "openai": "^4.80.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "overrides": {
    "noble": "npm:@abandonware/noble@^1.9.2-15"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
